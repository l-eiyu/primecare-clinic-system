{
  "info": {
    "name": "PrimeCare Clinic API",
    "description": "Postman collection for the PrimeCare Medical Clinic Appointment Booking System mock API (Chapter 8 / Appendix H testing evidence).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "appointmentId",
      "value": "APT-2026-0021",
      "type": "string"
    },
    {
      "key": "patientId",
      "value": "P-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Patients",
      "item": [
        {
          "name": "GET all patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            }
          },
          "response": []
        },
        {
          "name": "GET patient by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients/{{patientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "{{patientId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "GET all appointments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments"]
            }
          },
          "response": []
        },
        {
          "name": "GET appointment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}"]
            }
          },
          "response": []
        },
        {
          "name": "POST book new appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"P-001\",\n  \"patient_name\": \"Adrian Lei Frio\",\n  \"doctor_id\": \"D1001\",\n  \"doctor\": \"Dr. John Buena\",\n  \"service\": \"Orthopedics\",\n  \"appointment_date\": \"2026-04-20\",\n  \"appointment_time\": \"09:00 AM\",\n  \"mode\": \"Face-to-Face\",\n  \"payment_method\": \"card\",\n  \"amount\": 800\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/book",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "book"]
            }
          },
          "response": []
        },
        {
          "name": "PUT update appointment status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}"]
            }
          },
          "response": []
        },
        {
          "name": "DELETE cancel appointment",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
